# Copy to .env and adjust. Used by infra/compose/docker-compose.yml.

# Postgres / PostGIS
POSTGRES_USER=journeybook
POSTGRES_PASSWORD=journeybook
POSTGRES_DB=journeybook
# Host publish port for Postgres. 5433 by default to avoid clashing with a
# locally installed Postgres on 5432. The api connects to db:5432 inside the
# compose network regardless.
DB_PORT=5433

# Host ports
API_PORT=5180
WEB_PORT=8080

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
